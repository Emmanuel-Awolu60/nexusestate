<section class="page-hero page-hero--sm">
  <div class="container">
    <div class="section-eyebrow">Get in Touch</div>
    <h1 class="page-title">Contact Us</h1>
  </div>
</section>

<section class="section">
  <div class="container">
    {{#if success}}
    <div class="success-banner">
      ✓ Thank you! Your inquiry has been received. An advisor will be in touch within 24 hours.
    </div>
    {{/if}}

    <div class="contact-layout">
      <div class="contact-info">
        <h3>We'd Love to Hear From You</h3>
        <p>Whether you're buying, selling, leasing, or simply exploring — our team is ready to help. Reach us directly or fill out the form and we'll respond promptly.</p>

        <div class="contact-details">
          <div class="contact-item">
            <span class="contact-icon">📍</span>
            <div>
              <strong>New York HQ</strong>
              <p>120 Fifth Avenue, 12th Floor<br/>New York, NY 10011</p>
            </div>
          </div>
          <div class="contact-item">
            <span class="contact-icon">📞</span>
            <div>
              <strong>Phone</strong>
              <p>+1 (800) 639-8700</p>
            </div>
          </div>
          <div class="contact-item">
            <span class="contact-icon">✉</span>
            <div>
              <strong>Email</strong>
              <p>hello@nexusestate.com</p>
            </div>
          </div>
          <div class="contact-item">
            <span class="contact-icon">🕐</span>
            <div>
              <strong>Office Hours</strong>
              <p>Monday–Friday: 9am – 7pm<br/>Saturday: 10am – 4pm</p>
            </div>
          </div>
        </div>

        <div class="offices">
          <h4>Other Offices</h4>
          <ul>
            <li><strong>Chicago</strong> — 500 N Michigan Ave, Suite 800</li>
            <li><strong>Miami</strong> — 1111 Brickell Ave, Suite 1200</li>
            <li><strong>Los Angeles</strong> — 9000 Sunset Blvd, Suite 300</li>
          </ul>
        </div>
      </div>

      <div class="contact-form-wrap">
        <form class="contact-form" action="/inquiries" method="POST">
          <h3>Send a Message</h3>
          <div class="form-row">
            <div class="form-group">
              <label>First Name</label>
              <input type="text" name="firstName" placeholder="First name" required/>
            </div>
            <div class="form-group">
              <label>Last Name</label>
              <input type="text" name="lastName" placeholder="Last name" required/>
            </div>
          </div>
          <div class="form-group">
            <label>Email Address</label>
            <input type="email" name="email" placeholder="your@email.com" required/>
          </div>
          <div class="form-group">
            <label>Phone Number</label>
            <input type="tel" name="phone" placeholder="+1 (000) 000-0000"/>
          </div>
          <div class="form-group">
            <label>I'm interested in</label>
            <select name="interest">
              <option value="">Select an option</option>
              <option value="buying">Buying a Property</option>
              <option value="selling">Selling a Property</option>
              <option value="renting">Renting</option>
              <option value="investing">Investment Advisory</option>
              <option value="other">General Inquiry</option>
            </select>
          </div>
          <div class="form-group">
            <label>Message</label>
            <textarea name="message" rows="5" placeholder="Tell us how we can help..."></textarea>
          </div>
          <button type="submit" class="btn btn--primary btn--full">Send Message</button>
          <p class="form-note">By submitting, you agree to our Privacy Policy. We'll never share your information.</p>
        </form>
      </div>
    </div>
  </div>
</section>
