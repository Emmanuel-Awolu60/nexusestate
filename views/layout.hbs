<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{{title}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/main.css"/>
</head>
<body>

<header class="site-header" id="siteHeader">
  <nav class="nav-inner">
    <a href="/" class="logo">
      <span class="logo-mark">N</span>
      <span class="logo-text">NEXUS<strong>ESTATE</strong></span>
    </a>
    <ul class="nav-links">
      <li><a href="/" class="{{#if (eq page 'home')}}active{{/if}}">Home</a></li>
      <li><a href="/properties" class="{{#if (eq page 'properties')}}active{{/if}}">Properties</a></li>
      <li><a href="/about" class="{{#if (eq page 'about')}}active{{/if}}">About</a></li>
      <li><a href="/contact" class="{{#if (eq page 'contact')}}active{{/if}}">Contact</a></li>
    </ul>
    <a href="/contact" class="nav-cta">Book a Consultation</a>
    <button class="nav-toggle" id="navToggle" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </nav>
</header>

<main>
  {{{body}}}
</main>

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/" class="logo logo--light">
        <span class="logo-mark">N</span>
        <span class="logo-text">NEXUS<strong>ESTATE</strong></span>
      </a>
      <p>Premium real estate advisory for discerning buyers, sellers, and investors across North America's most coveted markets.</p>
    </div>
    <div class="footer-links">
      <h4>Properties</h4>
      <ul>
        <li><a href="/properties?type=sale">For Sale</a></li>
        <li><a href="/properties?type=rent">For Rent</a></li>
        <li><a href="/properties?category=luxury">Luxury</a></li>
        <li><a href="/properties?category=commercial">Commercial</a></li>
      </ul>
    </div>
    <div class="footer-links">
      <h4>Company</h4>
      <ul>
        <li><a href="/about">About Us</a></li>
        <li><a href="/contact">Contact</a></li>
        <li><a href="#">Privacy Policy</a></li>
        <li><a href="#">Terms of Service</a></li>
      </ul>
    </div>
    <div class="footer-contact">
      <h4>Get in Touch</h4>
      <p>hello@nexusestate.com</p>
      <p>+1 (800) 639-8700</p>
      <p>120 Fifth Avenue, 12th Floor<br/>New York, NY 10011</p>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; 2025 NexusEstate. All rights reserved.</p>
    <p>A concept project by <strong> <a href="https://builtbystudio.vercel.app/" target="_blank">BuiltBy Studio</a></strong></p>
  </div>
</footer>

<script src="/js/main.js"></script>
